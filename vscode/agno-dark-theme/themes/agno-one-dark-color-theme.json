  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#838383",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#10B981"
      }
    },
    {
      "name": "Docstrings",
      "scope": [
        "string.quoted.docstring",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#34D399"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF4017",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Controls",
      "scope": [
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#F25837",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#F0F0F0"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#BBBBBB"
      }
    },
    {
      "name": "Classes and Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#60A5FA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "identifier"
      ],
      "settings": {
        "foreground": "#D9D9D9"
      }
    },
    {
      "name": "Constants and Numbers",
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#FBBF24"
      }
    },
    {
      "name": "Operators and Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#8D8D8D"
      }
    },
    {
      "name": "Imports and Modules",
      "scope": [
        "keyword.control.import",
        "entity.name.namespace",
        "support.module"
      ],
      "settings": {
        "foreground": "#BBBBBB"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#EB6E52",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F87171",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#BBBBBB",
    "type": "#60A5FA",
    "class": {
      "foreground": "#60A5FA",
      "bold": true
    },
    "enum": "#60A5FA",
    "interface": "#60A5FA",
    "struct": "#60A5FA",
    "typeParameter": "#60A5FA",
    "parameter": "#BBBBBB",
    "variable": "#D9D9D9",
    "property": "#D9D9D9",
    "enumMember": "#FBBF24",
    "function": "#F0F0F0",
    "method": "#F0F0F0",
    "macro": "#EB6E52",
    "keyword": {
      "foreground": "#FF4017",
      "bold": true
    },
    "modifier": "#FF4017",
    "comment": {
      "foreground": "#838383",
      "italic": true
    },
    "string": "#10B981",
    "number": "#FBBF24",
    "regexp": "#34D399",
    "operator": "#8D8D8D",
    "decorator": {
      "foreground": "#EB6E52",
      "bold": true
    }
  }
}
